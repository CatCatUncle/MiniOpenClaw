# MiniOpenClaw environment configuration
# Load with: source .env

# Provider selection: gemini | openai | claude | ark | openai_compat
export MINICLAW_PROVIDER=gemini
export MINICLAW_MODEL="gemini-2.5-flash"

# Optional global overrides
# export MINICLAW_STREAM=false
# export MINICLAW_TIMEOUT_SECONDS=60
# export MINICLAW_MAX_RETRIES=2
# export MINICLAW_RETRY_BACKOFF_SECONDS=0.7
# export MINICLAW_MAX_AGENT_STEPS=8
# export MINICLAW_SEARCH_PROVIDER=brave
# export MINICLAW_WORKSPACE_ROOT=.
# export MINICLAW_SHELL_ALLOW_PREFIXES="ls,cat,rg,sed,head,tail,pwd,echo,mkdir"

# -------------------- Gemini --------------------
export GEMINI_API_KEY=""
export GEMINI_BASE_URL="https://api.aicodemirror.com/api/gemini"

# -------------------- OpenAI --------------------
export OPENAI_API_KEY=""
export OPENAI_BASE_URL="https://api.openai.com/v1"

# -------------------- Claude (Anthropic) --------------------
# export ANTHROPIC_API_KEY=""
# export ANTHROPIC_BASE_URL="https://api.aicodemirror.com/api/claudecode"

# -------------------- Volcano ARK --------------------
export ARK_API_KEY=""
export ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"

# -------------------- Generic OpenAI-Compatible --------------------
# Use when MINICLAW_PROVIDER=openai_compat
export MINICLAW_API_KEY=""
export MINICLAW_BASE_URL=""

# -------------------- Web Search --------------------
# Web search provider enum: brave | tavily
export MINICLAW_SEARCH_PROVIDER="tavily"
export BRAVE_SEARCH_API_KEY=""
export TAVILY_API_KEY=""

# -------------------- Telegram Channel --------------------
export MINICLAW_TELEGRAM_ENABLED=true
export TELEGRAM_BOT_TOKEN=""
export TELEGRAM_ALLOW_FROM=""
# export TELEGRAM_POLL_INTERVAL_SECONDS=1.5
# export TELEGRAM_MAX_CHUNK_CHARS=3500

# -------------------- Feishu Channel --------------------
export MINICLAW_FEISHU_ENABLED=false
export FEISHU_APP_ID=""
export FEISHU_APP_SECRET=""
export FEISHU_VERIFY_TOKEN=""
export FEISHU_WEBHOOK_HOST="127.0.0.1"
export FEISHU_WEBHOOK_PORT=8765
export FEISHU_WEBHOOK_PATH="/feishu/webhook"
# export FEISHU_ALLOW_FROM="ou_xxx,ou_yyy"
# export FEISHU_ALLOW_CHAT_IDS="oc_xxx,oc_yyy"
# export FEISHU_MAX_CHUNK_CHARS=1800
